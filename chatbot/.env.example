# Runtime
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text

# Catalog source. Leave both blank to use the bundled representative catalog.
CATALOG_PATH=
CATALOG_URL=
CATALOG_TIMEOUT_SECONDS=3.0

# Sessions
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=1800
SESSION_HISTORY_LIMIT=12

# Tiny outcome classification (optional; deterministic fallback is built in)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_INTENT_TIMEOUT_MS=1400

# Grounded response synthesis providers (optional)
GROQ_API_KEY=
GROQ_SYNTHESIS_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_SYNTHESIS_MODEL=gpt-4.1-mini
# Keep catalog answers deterministic/instant unless narrative rewriting is explicitly wanted.
ENABLE_ANSWER_SYNTHESIS=false
LLM_SYNTHESIS_TIMEOUT_SECONDS=5.0
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_COOLDOWN_SECONDS=30

# CRM lead webhook (optional)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=3.0
DEAD_LETTER_PATH=var/lead_dead_letters.jsonl
LEAD_PROMPT_AFTER_TURN=3
LEAD_PROMPT_INTERVAL=2

# Optional bearer token for POST /admin/reindex. Blank keeps it open for local use.
ADMIN_API_KEY=
