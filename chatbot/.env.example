# Runtime
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text

# Catalog source. Leave both blank to use the bundled representative catalog.
CATALOG_PATH=
CATALOG_URL=
CATALOG_TIMEOUT_SECONDS=5.0

# Sessions (Redis)
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=1800

# Widget configuration & path overrides. Leave blank to use bundled defaults.
WIDGET_CONFIG_PATH=
CHIP_MAP_PATH=
TOOLS_CONTENT_PATH=
# Public embeds need cross-origin GET/POST access. Use a comma-separated allowlist in production.
WIDGET_ALLOWED_ORIGINS=*

# CRM lead webhook (optional)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=5.0
DEAD_LETTER_PATH=var/lead_dead_letters.jsonl

# Funnel analytics (optional). Delivery never blocks a guided response.
ANALYTICS_WEBHOOK_URL=
ANALYTICS_WEBHOOK_SECRET=
ANALYTICS_TIMEOUT_SECONDS=1.0
ANALYTICS_DEAD_LETTER_PATH=var/analytics_dead_letters.jsonl
ANALYTICS_QUEUE_SIZE=2048

# Optional bearer token for POST /admin/reindex. Blank keeps it open for local use.
ADMIN_API_KEY=
